# ============================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env.production and fill in your values
# NEVER commit actual .env files to version control

# ============================================
# REQUIRED - OpenAI Configuration
# ============================================
OPENAI_API_KEY=sk-proj-your_production_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
MAX_TOKENS=4096
TEMPERATURE=0.7

# ============================================
# REQUIRED - Database Configuration
# ============================================
# For production, consider PostgreSQL instead of SQLite
DATABASE_URL=postgresql://user:password@host:5432/devpilot_prod
# Or use SQLite for simpler deployments
# DATABASE_URL=sqlite:///./devpilot_prod.db

# ============================================
# REQUIRED - Server Configuration
# ============================================
HOST=0.0.0.0
PORT=8000
RELOAD=false
WORKERS=4

# ============================================
# REQUIRED - CORS Configuration
# ============================================
# Add your production frontend URLs (comma-separated)
CORS_ORIGINS=https://your-app.vercel.app,https://www.your-domain.com

# ============================================
# OPTIONAL - GitHub Configuration
# ============================================
GITHUB_TOKEN=ghp_your_github_personal_access_token_here

# ============================================
# Application Settings
# ============================================
APP_NAME=DevPilot AI
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO
ENVIRONMENT=production

# ============================================
# Vector Store Configuration
# ============================================
CHROMA_PERSIST_DIRECTORY=./chroma_data
CHROMA_COLLECTION_NAME=devpilot_embeddings

# ============================================
# RAG Configuration
# ============================================
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RESULTS=5
SIMILARITY_THRESHOLD=0.7

# ============================================
# Cache Configuration
# ============================================
CACHE_TTL=3600
ENABLE_CACHE=true

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ============================================
# Security Settings
# ============================================
SECRET_KEY=your_secret_key_for_jwt_signing_change_this_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# Monitoring & Logging
# ============================================
SENTRY_DSN=https://your_sentry_dsn_here
ENABLE_METRICS=true
LOG_FILE=./logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ============================================
# External Services
# ============================================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# ============================================
# Feature Flags
# ============================================
ENABLE_LIVE_MEETING=true
ENABLE_GITHUB_ANALYSIS=true
ENABLE_TRANSCRIPT_PROCESSING=true
ENABLE_AI_MODES=true

# Made with Bob